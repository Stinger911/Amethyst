# Go
/bin/
*.exe
*.test

# Node / React frontend
node_modules/
dist/
build/

# internal/webui/dist is vite's build output, embedded into the Go binary
# (see internal/webui/embed.go) — keep the placeholder so go:embed has
# something to embed before the frontend has ever been built.
!/internal/webui/dist/
/internal/webui/dist/*
!/internal/webui/dist/placeholder.txt

# Env / secrets
.env
.env.*
!.env.example

# Local data
*.db
*.sqlite
*.sqlite3
/data/

# OS / editor
.DS_Store
.idea/
.vscode/
