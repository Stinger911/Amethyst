# Copy to .env and fill in before running `docker compose up`.

# Absolute path on the host to the real Obsidian vault to open.
VAULT_HOST_PATH=/path/to/your/vault

# Required: password for the password-fallback login.
ADMIN_PASSWORD=change-me

# Set to true once to force-reset ADMIN_PASSWORD on next start, then unset it.
ADMIN_PASSWORD_RESET=false

# Optional: enables the Telegram Login Widget + bot. Leave blank to disable.
TELEGRAM_BOT_TOKEN=
# Optional: can also be paired dynamically later from the /settings page
# ("Link Telegram") instead of setting this by hand.
TELEGRAM_OWNER_CHAT_ID=
TELEGRAM_BOT_USERNAME=

# Optional: TELEGRAM_MODE defaults to "polling" (works behind NAT/firewall,
# no public endpoint needed). Set to "webhook" only if Amethyst already has
# a public HTTPS URL (e.g. via your own reverse proxy, or the optional
# `tunnel` Docker Compose profile) — then TELEGRAM_WEBHOOK_URL is required
# and should point at that URL + /api/telegram/webhook.
TELEGRAM_MODE=polling
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=
