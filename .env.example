# Copy to .env and fill in before running `docker compose up`.

# Absolute path on the host to the real Obsidian vault to open.
VAULT_HOST_PATH=/path/to/your/vault

# Required: password for the password-fallback login.
ADMIN_PASSWORD=change-me

# Set to true once to force-reset ADMIN_PASSWORD on next start, then unset it.
ADMIN_PASSWORD_RESET=false

# Optional: enables the Telegram Login Widget + bot. Leave blank to disable.
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=
TELEGRAM_BOT_USERNAME=
